generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  ENGINEER
  TECHNICIAN
  WORKER
  FINANCIAL
  VIEWER
}

/// Papel do membro dentro de uma empresa específica
enum MemberRole {
  OWNER    // Proprietário — permissions: { all: true }
  ADMIN    // Administrador — permissions: { all: true }
  MANAGER  // Gestor — acesso a todos os módulos
  MEMBER   // Membro interno (engenheiro, técnico)
  EXTERNAL // Externo (mestre de obra) — só diário de obra
  CLIENT   // Cliente final — só visualização do progresso
}

/// Tipo de membro para controle de interface e fluxo de convite
enum MemberType {
  INTERNAL // Usuário interno da empresa
  EXTERNAL // Prestador / mestre de obra
  CLIENT   // Cliente final da construtora
}

enum CompanyPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  IN_PROGRESS
  PAUSED
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectStageStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum TransactionStatus {
  PENDING
  PAID
  CANCELLED
  OVERDUE
}

enum SubscriptionStatus {
  ACTIVE
  PENDING
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER
  TRANSFER_OUT    // saída do local origem em uma transferência
  TRANSFER_IN     // entrada no local destino em uma transferência
  RETURN
  LOSS
  EPI_DELIVERY
}

enum ToolMovementType {
  CHECKOUT
  RETURN
  MAINTENANCE
  LOST
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
}

enum ProblemStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ProblemPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DocumentType {
  CONTRACT
  REPORT
  BLUEPRINT
  PERMIT
  CERTIFICATE
  INVOICE
  OTHER
}

enum SignatureStatus {
  PENDING
  SIGNED
  REJECTED
}

/// Status de aprovação do registro diário
enum DiaryStatus {
  DRAFT    // Rascunho — não enviado para aprovação
  PENDING  // Preenchido, aguardando aprovação do gestor
  APPROVED // Aprovado pelo gestor
  REJECTED // Devolvido para correção
}

/// Condição climática por período
enum WeatherCondition {
  SUNNY    // Ensolarado
  CLOUDY   // Nublado
  OVERCAST // Encoberto
  RAINY    // Chuvoso
  STORMY   // Tempestade
}

/// Tipo de ocorrência no diário
enum OccurrenceType {
  ACCIDENT       // Acidente
  INCIDENT       // Incidente
  VISIT          // Visita
  INSPECTION     // Fiscalização / Vistoria
  STOPPAGE       // Paralisação
  NONCONFORMITY  // Não conformidade
  OTHER          // Outro
}

/// Severidade da ocorrência
enum OccurrenceSeverity {
  LOW      // Baixa
  MEDIUM   // Média
  HIGH     // Alta
  CRITICAL // Crítica
}

/// Categoria temática do DDS
enum DdsCategory {
  HEIGHT_WORK      // Trabalho em altura
  EXCAVATION       // Escavação e fundações
  ELECTRICAL       // Elétrica e choques
  SCAFFOLDING      // Andaimes e plataformas
  TOOLS            // Ferramentas e equipamentos
  PPE              // EPIs e equipamentos de proteção
  FIRE             // Prevenção de incêndio
  CHEMICAL         // Produtos químicos e FISPQ
  ERGONOMICS       // Ergonomia e postura
  TRAFFIC          // Sinalização e trânsito
  HOUSEKEEPING     // Organização e limpeza (5S)
  LIFTING          // Içamento e movimentação de cargas
  CONCRETE         // Concretagem e formas
  MASONRY          // Alvenaria e revestimentos
  ROOFING          // Telhados e coberturas
  CONFINED_SPACE   // Espaço confinado
  FIRST_AID        // Primeiros socorros
  ACCIDENT_REPORT  // Comunicação de acidentes
  GENERAL_SAFETY   // Segurança geral
  HEALTH           // Saúde e bem-estar
  ENVIRONMENT      // Meio ambiente
  QUALITY          // Qualidade na obra
  OTHER            // Outros
}

// ─── Enums do módulo Financeiro ──────────────────────────────────────────────

enum PaymentMethod {
  PIX
  BOLETO
  TED
  DOC
  TRANSFER
  CREDIT_CARD
  DEBIT_CARD
  CASH
  CHECK
  DEBIT
  OTHER
}

enum TransactionOrigin {
  MANUAL
  OPEN_FINANCE
  OFX_IMPORT
  RECURRING
  SYSTEM
}

enum RecurringFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  BIMONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

enum CostType {
  MATERIAL
  LABOR
  EQUIPMENT
  SERVICE
  OTHER
}

enum AccountType {
  CHECKING
  SAVINGS
  INVESTMENT
  CASH
  CREDIT_CARD
  OTHER
}

enum IntegrationStatus {
  MANUAL
  PENDING
  ACTIVE
  ERROR
  INACTIVE
}

enum BankAccountStatus {
  ACTIVE
  INACTIVE
  CLOSED
}

enum FinancialCategoryType {
  INCOME
  EXPENSE
  BOTH
}

// ─────────────────────────────────────────
// USUÁRIOS & AUTENTICAÇÃO
// ─────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String?   @map("password_hash")
  avatarUrl          String?   @map("avatar_url")
  savedSignatureUrl  String?   @map("saved_signature_url")
  phone        String?
  cpf          String?   @unique
  isActive     Boolean   @default(true) @map("is_active")
  emailVerifiedAt DateTime? @map("email_verified_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  sessions       Session[]
  companyMembers CompanyMember[]
  invitesSent    Invite[]        @relation("InviteSender")
  invitesReceived Invite[]       @relation("InviteReceiver")
  auditLogs      AuditLog[]
  signatures     Signature[]
  epiDeliveries  EpiDelivery[]   @relation("EpiResponsible")
  toolMovements  ToolMovement[]  @relation("ToolResponsible")
  diaryEntries    DiaryEntry[]    @relation("DiaryAuthor")
  stockMovementsResponsible StockMovement[] @relation("StockMovementResponsible")
  toolCustodiesResponsible  ToolCustody[]   @relation("ToolCustodyResponsible")
  stockEpiDeliveriesResponsible StockEpiDelivery[] @relation("StockEpiResponsible")
  stockBasketsResponsible   StockBasket[]   @relation("BasketResponsible")
  // Multi-local
  stockLocationsManaged     StockLocation[]           @relation("LocationManager")
  stockLocationPermissions  StockLocationPermission[]
  stockTransfersRequested   StockTransfer[]           @relation("TransferRequester")
  stockTransfersResponded   StockTransfer[]           @relation("TransferResponder")
  diaryApprovals  DiaryEntry[]    @relation("DiaryApprover")
  diaryRejections DiaryEntry[]    @relation("DiaryRejector")
  diaryComments   DiaryComment[]
  ddsThemesCreated DdsTheme[]     @relation("DdsCreatedBy")
  problemComments ProblemComment[]
  financialTransactions FinancialTransaction[] @relation("FinancialCreatedBy")
  financialAuditLogs    FinancialAuditLog[]
  projectsResponsible   Project[]              @relation("ProjectResponsible")
  clientsCreated        Client[]               @relation("ClientCreatedBy")
  suppliersCreated      Supplier[]             @relation("SupplierCreatedBy")
  waybillsAsSender      Waybill[]
  notifications         Notification[]
  toolDeleteRequestsMade ToolDeleteRequest[] @relation("DeleteRequestor")

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  userAgent String?  @map("user_agent")
  ipAddress String?  @map("ip_address")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─────────────────────────────────────────
// EMPRESA (TENANT)
// ─────────────────────────────────────────

model Company {
  id          String      @id @default(cuid())
  name        String
  cnpj        String?     @unique
  logo        String?
  slogan      String?                          // slogan da empresa (exibido na placa de obra)
  address     String?
  city        String?
  state       String?
  zipCode     String?     @map("zip_code")
  phone       String?
  email       String?
  website     String?
  plan                 CompanyPlan @default(FREE)
  isActive             Boolean     @default(true) @map("is_active")
  trialEndsAt          DateTime?   @map("trial_ends_at")
  stripeCustomerId      String?            @unique @map("stripe_customer_id")
  stripeSubscriptionId  String?            @map("stripe_subscription_id")
  subscriptionStatus    SubscriptionStatus @default(ACTIVE) @map("subscription_status")
  subscriptionExpiresAt DateTime?          @map("subscription_expires_at")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  members              CompanyMember[]
  memberProjectAccesses MemberProjectAccess[]
  invites              Invite[]
  addons               CompanyAddon[]
  projects             Project[]
  clients              Client[]
  suppliers            Supplier[]
  bankAccounts         BankAccount[]
  transactions         Transaction[]
  employees            Employee[]
  stockItems           StockItem[]
  vehicles             Vehicle[]
  problems             Problem[]
  documents            Document[]
  documentTemplates    DocumentTemplate[]
  auditLogs            AuditLog[]
  purchaseMaps         PurchaseMap[]
  ddsThemes            DdsTheme[]
  financialTransactions FinancialTransaction[]
  financialCategories   FinancialCategory[]
  recurringTransactions RecurringTransaction[]
  financialAuditLogs    FinancialAuditLog[]
  payrollDrafts         PayrollDraft[]
  stockMovements        StockMovement[]
  toolCustodies         ToolCustody[]
  projectCostEntries    ProjectCostEntry[]
  stockEpiDeliveries    StockEpiDelivery[]
  supplierLots          SupplierLot[]
  stockBaskets          StockBasket[]
  toolMaintenanceRecords ToolMaintenanceRecord[]
  stockLocations        StockLocation[]
  stockTransfers        StockTransfer[]
  stockBalances         StockBalance[]
  waybills              Waybill[]
  notifications         Notification[]
  toolDeleteRequests    ToolDeleteRequest[]
  projectCloseRequests  ProjectCloseRequest[]

  @@map("companies")
}

model CompanyMember {
  id          String     @id @default(cuid())
  companyId   String     @map("company_id")
  userId      String     @map("user_id")
  role        UserRole   @default(VIEWER)
  /// Papel estruturado do membro na empresa (OWNER, ADMIN, MANAGER, MEMBER, EXTERNAL, CLIENT)
  memberRole  MemberRole @default(MEMBER) @map("member_role")
  /// Tipo para controle de interface (INTERNAL, EXTERNAL, CLIENT)
  memberType  MemberType @default(INTERNAL) @map("member_type")
  /// JSON de permissões por módulo. Ex: {"financeiro":["view","create"]} ou {"all":true}
  permissions Json?
  joinedAt    DateTime   @default(now()) @map("joined_at")
  isActive    Boolean    @default(true) @map("is_active")

  company      Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectAccesses MemberProjectAccess[]

  @@unique([companyId, userId])
  @@map("company_members")
}

/// Controla quais obras um membro MEMBER pode acessar (OWNER/ADMIN/MANAGER veem todas)
model MemberProjectAccess {
  id        String   @id @default(cuid())
  memberId  String   @map("member_id")
  projectId String   @map("project_id")
  companyId String   @map("company_id")

  member  CompanyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([memberId, projectId])
  @@map("member_project_access")
}

model Invite {
  id          String      @id @default(cuid())
  companyId   String      @map("company_id")
  senderId    String      @map("sender_id")
  receiverId  String?     @map("receiver_id")
  email       String
  role        UserRole    @default(VIEWER)
  memberRole  MemberRole  @default(MEMBER) @map("member_role")
  memberType  MemberType  @default(INTERNAL) @map("member_type")
  /// Permissões que serão aplicadas quando o convite for aceito
  permissions Json?
  token       String      @unique @default(cuid())
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime    @map("expires_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sender   User     @relation("InviteSender", fields: [senderId], references: [id])
  receiver User?    @relation("InviteReceiver", fields: [receiverId], references: [id])

  @@map("invites")
}

model CompanyAddon {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  addonKey  String   @map("addon_key")
  isEnabled Boolean  @default(true) @map("is_enabled")
  config    Json?
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, addonKey])
  @@map("company_addons")
}

// ─────────────────────────────────────────
// PROJETOS / OBRAS
// ─────────────────────────────────────────

model Project {
  id                String        @id @default(cuid())
  companyId         String        @map("company_id")
  clientId          String?       @map("client_id")
  responsibleId     String?       @map("responsible_id")
  code              String?       @map("code")
  name              String
  description       String?
  address           String?
  city              String?
  state             String?
  zipCode           String?       @map("zip_code")
  status            ProjectStatus @default(ACTIVE)
  globalBudget      Decimal?      @db.Decimal(15, 2) @map("global_budget")
  budget            Decimal?      @db.Decimal(15, 2)
  contractValue     Decimal?      @db.Decimal(15, 2) @map("contract_value")
  startDate         DateTime?     @map("start_date")
  endDate           DateTime?     @map("end_date")
  expectedEndDate   DateTime?     @map("expected_end_date")
  actualEndDate     DateTime?     @map("actual_end_date")
  warrantyMonths    Int           @default(60)  @map("warranty_months")
  progressPercent   Decimal       @default(0) @db.Decimal(5, 2) @map("progress_percent")
  budgetAlert       Boolean       @default(false) @map("budget_alert")
  delayAlert        Boolean       @default(false) @map("delay_alert")
  cno               String?       @map("cno")
  artExecution      String?       @map("art_execution")
  artExecutionFile  String?       @map("art_execution_file")
  artProjects       String?       @map("art_projects")
  artProjectsFile   String?       @map("art_projects_file")
  technicalName     String?       @map("technical_name")
  technicalTitle    String?       @map("technical_title")
  technicalCrea     String?       @map("technical_crea")
  technicalPhoto    String?       @map("technical_photo")
  coverImage        String?       @map("cover_image")
  // Dados técnicos adicionais da obra
  totalArea         Decimal?      @db.Decimal(10, 2) @map("total_area")   // área total construída (m²)
  floors            Int?          @map("floors")                           // número de pavimentos
  buildingPermit    String?       @map("building_permit")                 // alvará de construção
  slogan            String?       @map("slogan")                          // slogan da obra (placa)
  diaryMaxPhotos    Int           @default(10) @map("diary_max_photos")   // máximo de fotos por RDO
  isActive          Boolean       @default(true) @map("is_active")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  company               Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client                Client?               @relation(fields: [clientId], references: [id])
  responsible           User?                 @relation("ProjectResponsible", fields: [responsibleId], references: [id])
  stages                ProjectStage[]
  transactions          Transaction[]
  stockMovements        StockMovement[]
  toolMovements         ToolMovement[]
  problems              Problem[]
  diaryEntries          DiaryEntry[]
  diaryRainRecords      DiaryRainRecord[]
  documents             Document[]
  purchaseMaps          PurchaseMap[]
  memberAccesses        MemberProjectAccess[]
  costCenterAllocations CostCenterAllocation[]
  financialTransactions FinancialTransaction[]
  employees             Employee[]
  employeeHistory       EmployeeProjectHistory[]
  currentStockItems     StockItem[]             @relation("StockCurrentProject")
  toolCustodies         ToolCustody[]
  projectCostEntries    ProjectCostEntry[]
  stockEpiDeliveries    StockEpiDelivery[]
  stockBaskets          StockBasket[]
  projectFiles          ProjectFile[]
  projectFolders        ProjectFolder[]
  stockLocations        StockLocation[]
  waybills              Waybill[]
  closeRequests         ProjectCloseRequest[]

  @@map("projects")
}

// ─────────────────────────────────────────
// OBRA — Solicitação de Encerramento
// ─────────────────────────────────────────

/// Solicitação de encerramento de obra com aprovação do gestor
model ProjectCloseRequest {
  id           String    @id @default(cuid())
  companyId    String    @map("company_id")
  projectId    String    @map("project_id")
  requestedBy  String    @map("requested_by")   // userId
  requestedAt  DateTime  @default(now()) @map("requested_at")
  reason       String?
  status       String    @default("PENDING") @map("status")
  // PENDING | APPROVED | REJECTED
  pendingTools Int       @default(0) @map("pending_tools")
  reviewedBy   String?   @map("reviewed_by")
  reviewedAt   DateTime? @map("reviewed_at")
  reviewNotes  String?   @map("review_notes")
  isActive     Boolean   @default(true) @map("is_active")

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@map("project_close_requests")
}

// ─────────────────────────────────────────
// DEPÓSITO — Registro de Manutenção de Ferramenta
// ─────────────────────────────────────────

/// Histórico de manutenções de ferramentas/equipamentos
model ToolMaintenanceRecord {
  id          String    @id @default(cuid())
  companyId   String    @map("company_id")
  stockItemId String    @map("stock_item_id")
  type        String    @default("PREVENTIVE") // PREVENTIVE | CORRECTIVE | INSPECTION
  date        DateTime
  performedBy String?   @map("performed_by")   // empresa/pessoa que realizou
  description String
  cost        Decimal?  @db.Decimal(10, 2)
  nextDate    DateTime? @map("next_date")
  result      String?                          // OK | NEEDS_PARTS | WAITING_QUOTE
  fileUrl     String?   @map("file_url")        // comprovante (PDF/foto)
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stockItem StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@index([stockItemId])
  @@map("tool_maintenance_records")
}

/// Hierarquia de pastas para organizar arquivos do projeto
model ProjectFolder {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  projectId String   @map("project_id")
  name      String
  parentId  String?  @map("parent_id")    // null = pasta raiz
  path      String   @default("")          // "Arquitetura/R01/Estrutura"
  color     String?                        // cor de destaque hex
  order     Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project  Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent   ProjectFolder?  @relation("FolderChildren", fields: [parentId], references: [id])
  children ProjectFolder[] @relation("FolderChildren")
  files    ProjectFile[]

  @@index([projectId])
  @@index([parentId])
  @@map("project_folders")
}

/// Pasta de Projetos — arquivos técnicos vinculados à obra (PDF, DWG, IFC, etc.)
model ProjectFile {
  id           String    @id @default(cuid())
  companyId    String    @map("company_id")
  projectId    String    @map("project_id")
  folderId     String?   @map("folder_id")   // pasta onde está (null = raiz)
  name         String                         // nome amigável exibido na UI
  originalName String    @map("original_name")  // nome original do arquivo
  type         String                         // mime type (application/pdf, etc.)
  size         Int                            // tamanho em bytes
  url          String                         // caminho relativo em disco
  category     String    @default("other")    // pdf | dwg | ifc | other
  description  String?
  version      String?                        // ex: "Rev. 2", "v3"
  uploadedBy   String?   @map("uploaded_by")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder  ProjectFolder? @relation(fields: [folderId], references: [id])

  @@index([projectId, category])
  @@index([folderId])
  @@map("project_files")
}

model ProjectStage {
  id              String             @id @default(cuid())
  projectId       String             @map("project_id")
  code            String?            @map("code")
  name            String
  description     String?
  order           Int                @default(0)
  status          ProjectStageStatus @default(PENDING)
  startDate       DateTime?          @map("start_date")
  endDate         DateTime?          @map("end_date")
  progress        Int                @default(0)
  budgetMaterial  Decimal            @default(0) @db.Decimal(14, 2) @map("budget_material")
  budgetLabor     Decimal            @default(0) @db.Decimal(14, 2) @map("budget_labor")
  budgetTotal     Decimal            @default(0) @db.Decimal(14, 2) @map("budget_total")
  realizedValue   Decimal            @default(0) @db.Decimal(14, 2) @map("realized_value")
  progressPercent Decimal            @default(0) @db.Decimal(5, 2) @map("progress_percent")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  project               Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  costCenterAllocations CostCenterAllocation[]
  diaryStageEntries     DiaryStageEntry[]
  costEntries           ProjectCostEntry[]

  @@map("project_stages")
}

// ─────────────────────────────────────────
// CLIENTES & FORNECEDORES
// ─────────────────────────────────────────

model Client {
  id            String   @id @default(cuid())
  companyId     String   @map("company_id")
  createdById   String?  @map("created_by_id")
  type          String   @default("COMPANY") @map("type") // PERSON | COMPANY
  name          String
  tradeName     String?  @map("trade_name")
  email         String?
  phone         String?
  phone2        String?  @map("phone2")
  whatsapp      String?  @map("whatsapp")
  cpfCnpj       String?  @map("cpf_cnpj")
  address       String?
  city          String?
  state         String?
  zipCode       String?  @map("zip_code")
  // Contato principal (PJ)
  contactName   String?  @map("contact_name")
  contactRole   String?  @map("contact_role")
  contactEmail  String?  @map("contact_email")
  contactPhone  String?  @map("contact_phone")
  notes         String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  company               Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy             User?                 @relation("ClientCreatedBy", fields: [createdById], references: [id])
  projects              Project[]
  financialTransactions FinancialTransaction[]

  @@map("clients")
}

model Supplier {
  id            String   @id @default(cuid())
  companyId     String   @map("company_id")
  createdById   String?  @map("created_by_id")
  type          String   @default("COMPANY") @map("type") // PERSON | COMPANY
  name          String
  tradeName     String?  @map("trade_name")
  email         String?
  phone         String?
  phone2        String?  @map("phone2")
  whatsapp      String?  @map("whatsapp")
  cnpj          String?                                   // legado — usar cpfCnpj para novas entradas
  cpfCnpj       String?  @map("cpf_cnpj")                // CPF (PF) ou CNPJ (PJ)
  category      String?  @map("category")                // MATERIAL | LABOR | SERVICE | EQUIPMENT | TRANSPORT | OTHER
  address       String?
  city          String?
  state         String?
  zipCode       String?  @map("zip_code")
  contactName   String?  @map("contact_name")
  contactRole   String?  @map("contact_role")
  contactEmail  String?  @map("contact_email")
  contactPhone  String?  @map("contact_phone")
  // Campos PF (autônomo)
  profession    String?  @map("profession")
  crea          String?  @map("crea")
  // Campos PJ
  stateRegistration     String? @map("state_registration")
  municipalRegistration String? @map("municipal_registration")
  // Dados bancários (para conciliação)
  bankName      String?  @map("bank_name")
  bankCode      String?  @map("bank_code")
  bankAgency    String?  @map("bank_agency")
  bankAccount   String?  @map("bank_account")
  bankAccountType String? @map("bank_account_type")
  pixKey        String?  @map("pix_key")
  pixKeyType    String?  @map("pix_key_type")
  rating        Int?     @map("rating")
  notes         String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  company               Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy             User?                 @relation("SupplierCreatedBy", fields: [createdById], references: [id])
  purchaseOrders        PurchaseOrder[]
  purchaseQuotations    PurchaseQuotation[]
  financialTransactions FinancialTransaction[]
  recurringTransactions RecurringTransaction[]
  supplierLots          SupplierLot[]
  employees             Employee[]            @relation("EmployeeSupplier")

  @@map("suppliers")
}

// ─────────────────────────────────────────
// FINANCEIRO — MODELOS BÁSICOS
// ─────────────────────────────────────────

model BankAccount {
  id               String            @id @default(cuid())
  companyId        String            @map("company_id")
  name             String
  bank             String?
  bankId           String?           @map("bank_id")
  agency           String?
  agencyDigit      String?           @map("agency_digit")
  accountNumber    String?           @map("account_number")
  accountDigit     String?           @map("account_digit")
  accountType      AccountType       @default(CHECKING) @map("account_type")
  pixKey           String?           @map("pix_key")
  holderName       String?           @map("holder_name")
  holderDocument   String?           @map("holder_document")
  initialBalance   Decimal           @default(0) @db.Decimal(14, 2) @map("initial_balance")
  balance          Decimal           @default(0) @db.Decimal(15, 2)
  integrationActive  Boolean           @default(false) @map("integration_active")
  integrationStatus  IntegrationStatus @default(MANUAL) @map("integration_status")
  lastSyncAt         DateTime?         @map("last_sync_at")
  isActive           Boolean           @default(true) @map("is_active")
  status             BankAccountStatus @default(ACTIVE) @map("status")
  inactivatedAt      DateTime?         @map("inactivated_at")
  inactivatedById    String?           @map("inactivated_by_id")
  inactivationReason String?           @map("inactivation_reason")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  company               Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bankRef               Bank?                  @relation(fields: [bankId], references: [id])
  transactions          Transaction[]
  financialTransactions FinancialTransaction[]
  recurringTransactions RecurringTransaction[]

  @@map("bank_accounts")
}

model Transaction {
  id            String            @id @default(cuid())
  companyId     String            @map("company_id")
  projectId     String?           @map("project_id")
  bankAccountId String?           @map("bank_account_id")
  type          TransactionType
  status        TransactionStatus @default(PENDING)
  description   String
  amount        Decimal           @db.Decimal(15, 2)
  dueDate       DateTime?         @map("due_date")
  paidAt        DateTime?         @map("paid_at")
  category      String?
  tags          String[]
  notes         String?
  attachmentUrl String?           @map("attachment_url")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  company     Company      @relation(fields: [companyId], references: [id])
  project     Project?     @relation(fields: [projectId], references: [id])
  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id])

  @@map("transactions")
}

// ─────────────────────────────────────────
// FINANCEIRO — MÓDULO COMPLETO
// ─────────────────────────────────────────

/// Lançamento financeiro completo com rateio, recorrência, auditoria e conciliação
model FinancialTransaction {
  id                String             @id @default(cuid())
  companyId         String             @map("company_id")
  createdById       String             @map("created_by_id")
  description       String
  type              TransactionType
  status            TransactionStatus  @default(PENDING)
  isPaid            Boolean            @default(false) @map("is_paid")
  grossAmount       Decimal            @db.Decimal(14, 2) @map("gross_amount")
  interestAmount    Decimal            @default(0) @db.Decimal(14, 2) @map("interest_amount")
  retentionAmount   Decimal            @default(0) @db.Decimal(14, 2) @map("retention_amount")
  netAmount         Decimal            @db.Decimal(14, 2) @map("net_amount")
  dueDate           DateTime?          @map("due_date")
  paidAt            DateTime?          @map("paid_at")
  referenceDate     DateTime           @map("reference_date")
  categoryId        String?            @map("category_id")
  bankAccountId     String?            @map("bank_account_id")
  paymentMethod     PaymentMethod?     @map("payment_method")
  invoiceNumber     String?            @map("invoice_number")
  clientId          String?            @map("client_id")
  supplierId        String?            @map("supplier_id")
  employeeId        String?            @map("employee_id")
  notes             String?
  attachments       String[]
  origin            TransactionOrigin  @default(MANUAL)
  bankTransactionId String?            @map("bank_transaction_id")
  isReconciled      Boolean            @default(false) @map("is_reconciled")
  reconciledAt      DateTime?          @map("reconciled_at")
  reconciledById    String?            @map("reconciled_by_id")
  isRecurring       Boolean            @default(false) @map("is_recurring")
  recurringId       String?            @map("recurring_id")
  installmentNumber Int?               @map("installment_number")
  totalInstallments Int?               @map("total_installments")
  projectId         String?            @map("project_id")
  transactionNumber String?            @map("transaction_number")
  transactionHash   String?            @unique @map("transaction_hash")
  isTransfer        Boolean            @default(false) @map("is_transfer")
  transferPairId    String?            @map("transfer_pair_id")
  isPayroll             Boolean?           @default(false) @map("is_payroll")
  payrollMonth          Int?               @map("payroll_month")
  payrollYear           Int?               @map("payroll_year")
  payrollEmployeeId     String?            @map("payroll_employee_id")
  observations          String?
  isActive          Boolean            @default(true) @map("is_active")
  deletedAt         DateTime?          @map("deleted_at")
  deletedById       String?            @map("deleted_by_id")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  company                Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy              User                 @relation("FinancialCreatedBy", fields: [createdById], references: [id])
  category               FinancialCategory?   @relation(fields: [categoryId], references: [id])
  bankAccount            BankAccount?         @relation(fields: [bankAccountId], references: [id])
  client                 Client?              @relation(fields: [clientId], references: [id])
  supplier               Supplier?            @relation(fields: [supplierId], references: [id])
  project                Project?             @relation(fields: [projectId], references: [id])
  recurringTransaction   RecurringTransaction? @relation(fields: [recurringId], references: [id])
  costCenterAllocations  CostCenterAllocation[]
  auditLogs              FinancialAuditLog[]

  @@index([companyId, referenceDate])
  @@index([companyId, isPaid, type])
  @@index([companyId, isActive])
  @@index([companyId, transactionNumber])
  @@index([companyId, transferPairId])
  @@map("financial_transactions")
}

/// Rascunho de folha de pagamento — salvo antes do lançamento oficial
model PayrollDraft {
  id                  String    @id @default(cuid())
  companyId           String    @map("company_id")
  month               Int
  year                Int
  status              String    @default("DRAFT")
  data                Json
  totalBruto          Decimal   @db.Decimal(14, 2) @map("total_bruto")
  totalLiquido        Decimal   @db.Decimal(14, 2) @map("total_liquido")
  totalColaboradores  Int       @map("total_colaboradores")
  observations        String?
  launchedAt          DateTime? @map("launched_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  createdBy           String    @map("created_by")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, month, year])
  @@index([companyId, year, month])
  @@map("payroll_drafts")
}

/// Rateio de um lançamento por centro de custo (obra/etapa)
model CostCenterAllocation {
  id            String    @id @default(cuid())
  transactionId String    @map("transaction_id")
  projectId     String    @map("project_id")
  stageId       String?   @map("stage_id")
  amount        Decimal   @db.Decimal(14, 2)
  percentage    Decimal   @db.Decimal(5, 2)
  costType      CostType?  @map("cost_type")
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")

  transaction FinancialTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  project     Project              @relation(fields: [projectId], references: [id])
  stage       ProjectStage?        @relation(fields: [stageId], references: [id])

  @@map("cost_center_allocations")
}

/// Categorias financeiras — padrão do sistema (companyId=null) ou personalizadas
model FinancialCategory {
  id        String                @id @default(cuid())
  companyId String?               @map("company_id")
  name      String
  type      FinancialCategoryType
  color     String?
  icon      String?
  isDefault Boolean               @default(false) @map("is_default")
  isActive  Boolean               @default(true) @map("is_active")
  order     Int                   @default(0)
  createdAt DateTime              @default(now()) @map("created_at")

  company      Company?               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transactions FinancialTransaction[]
  recurringTransactions RecurringTransaction[]

  @@map("financial_categories")
}

/// Regra de recorrência — gera parcelas periódicas automaticamente
model RecurringTransaction {
  id                String             @id @default(cuid())
  companyId         String             @map("company_id")
  description       String
  type              TransactionType
  amount            Decimal            @db.Decimal(14, 2)
  categoryId        String?            @map("category_id")
  bankAccountId     String?            @map("bank_account_id")
  supplierId        String?            @map("supplier_id")
  clientId          String?            @map("client_id")
  frequency         RecurringFrequency
  startDate         DateTime           @map("start_date")
  endDate           DateTime?          @map("end_date")
  totalInstallments Int?               @map("total_installments")
  generatedCount    Int                @default(0) @map("generated_count")
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at")

  company      Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category     FinancialCategory?     @relation(fields: [categoryId], references: [id])
  bankAccount  BankAccount?           @relation(fields: [bankAccountId], references: [id])
  supplier     Supplier?              @relation(fields: [supplierId], references: [id])
  transactions FinancialTransaction[]

  @@map("recurring_transactions")
}

/// Log de auditoria financeira por lançamento
model FinancialAuditLog {
  id            String   @id @default(cuid())
  companyId     String?  @map("company_id")        // para filtrar por empresa mesmo quando tx for deletada
  transactionId String?  @map("transaction_id")    // nullable para manter logs mesmo se tx for deletada
  userId        String?  @map("user_id")            // nullable caso usuário seja removido
  action        String   // CREATED | EDITED | PAID | CANCELLED | DELETED | RECONCILED
  previousData  Json?    @map("previous_data")
  newData       Json?    @map("new_data")
  ipAddress     String?  @map("ip_address")
  createdAt     DateTime @default(now()) @map("created_at")

  company     Company?              @relation(fields: [companyId], references: [id])
  transaction FinancialTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  user        User?                 @relation(fields: [userId], references: [id])

  @@index([companyId, createdAt])
  @@map("financial_audit_logs")
}

/// Catálogo de bancos brasileiros (populado via BrasilAPI)
model Bank {
  id       String  @id @default(cuid())
  code     String? @unique
  ispb     String  @unique
  name     String
  fullName String? @map("full_name")
  isActive Boolean @default(true) @map("is_active")

  bankAccounts BankAccount[]

  @@map("banks")
}

// ─────────────────────────────────────────
// RH — FUNCIONÁRIOS
// ─────────────────────────────────────────

model Employee {
  id               String    @id @default(cuid())
  companyId        String    @map("company_id")
  code             String    @map("code")
  name             String
  cpf              String?
  rg               String?
  ctps             String?
  pis              String?
  birthDate        DateTime? @map("birth_date")
  admissionDate    DateTime? @map("admission_date")
  dismissalDate    DateTime? @map("dismissal_date")
  email            String?
  phone            String?
  address          String?
  city             String?
  state            String?
  zipCode          String?   @map("zip_code")
  photo            String?
  position         String?   // legacy — use role
  role             String?
  department       String?
  type             String    @default("CLT")
  status           String    @default("ACTIVE")
  salary           Decimal?  @db.Decimal(10, 2)
  projectId        String?   @map("project_id")
  locationId       String?   @map("location_id")
  locationName     String?   @map("location_name")
  locationType     String?   @map("location_type")    // "FIXED" | "PROJECT"
  locationFixed    String?   @map("location_fixed")   // ex: "OFFICE", "VACATION"
  lastTransferDate DateTime? @map("last_transfer_date")
  bloodType        String?   @map("blood_type")
  emergencyContact String?   @map("emergency_contact")

  // ── Dados da empresa PJ ────────────────────────────────────────────────────
  pjCnpj         String?   @map("pj_cnpj")
  pjRazaoSocial  String?   @map("pj_razao_social")
  pjNomeFantasia String?   @map("pj_nome_fantasia")
  pjEmail        String?   @map("pj_email")
  pjPhone        String?   @map("pj_phone")

  // ── Dados bancários ────────────────────────────────────────────────────────
  bankType         String?   @map("bank_type")           // 'PIX' | 'TED_DOC'
  bankPixKey       String?   @map("bank_pix_key")
  bankPixKeyType   String?   @map("bank_pix_key_type")   // 'CPF'|'CNPJ'|'EMAIL'|'PHONE'|'RANDOM'
  bankName         String?   @map("bank_name")
  bankCode         String?   @map("bank_code")
  bankAgency       String?   @map("bank_agency")
  bankAgencyDigit  String?   @map("bank_agency_digit")
  bankAccount      String?   @map("bank_account")
  bankAccountDigit String?   @map("bank_account_digit")
  bankAccountType  String?   @map("bank_account_type")   // 'CORRENTE' | 'POUPANCA'
  bankHolderName   String?   @map("bank_holder_name")
  bankHolderDoc    String?   @map("bank_holder_doc")

  // ── Vínculo com fornecedor (PJ / Terceirizado) ────────────────────────────
  supplierId       String?   @map("supplier_id")

  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  company        Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project        Project?                 @relation(fields: [projectId], references: [id])
  supplier       Supplier?                @relation("EmployeeSupplier", fields: [supplierId], references: [id])
  documents      EmployeeDocument[]
  trainings      EmployeeTraining[]
  vacations      EmployeeVacation[]
  epiDeliveries  EpiDelivery[]
  toolMovements  ToolMovement[]           @relation("ToolEmployee")
  projectHistory EmployeeProjectHistory[]
  stockMovements StockMovement[]          @relation("StockMovementEmployee")
  toolCustodies  ToolCustody[]
  stockEpiDeliveries StockEpiDelivery[]
  stockBaskets          StockBasket[]  @relation("BasketEmployee")
  waybillsAsDriver      Waybill[]      @relation("WaybillDriver")
  waybillsAsReceiver    Waybill[]      @relation("WaybillReceiver")

  @@unique([companyId, code])
  @@index([companyId, status])
  @@index([companyId, projectId])
  @@index([supplierId])
  @@map("employees")
}

model EmployeeDocument {
  id           String    @id @default(cuid())
  companyId    String    @map("company_id")
  employeeId   String    @map("employee_id")
  type         String
  name         String
  fileUrl      String?   @map("file_url")
  fileType     String?   @map("file_type")
  issueDate    DateTime? @map("issue_date")
  expiryDate   DateTime? @map("expiry_date")
  observations String?
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([companyId, expiryDate])
  @@map("employee_documents")
}

model EmployeeTraining {
  id              String    @id @default(cuid())
  companyId       String    @map("company_id")
  employeeId      String    @map("employee_id")
  name            String
  provider        String?
  workload        Int?
  completedAt     DateTime  @map("completed_at")
  expiresAt       DateTime? @map("expires_at")
  certificateUrl  String?   @map("certificate_url")
  certificateType String?   @map("certificate_type")
  observations    String?
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([companyId, expiresAt])
  @@map("employee_trainings")
}

model EmployeeVacation {
  id           String    @id @default(cuid())
  companyId    String    @map("company_id")
  employeeId   String    @map("employee_id")
  startDate    DateTime  @map("start_date")
  endDate      DateTime  @map("end_date")
  days         Int
  status       String    @default("SCHEDULED")
  observations String?
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")

