// ─────────────────────────────────────────
// ESTOQUE
// ─────────────────────────────────────────

model StockItem {
  id               String   @id @default(cuid())
  companyId        String   @map("company_id")
  name             String
  description      String?
  category         String?
  unit             String   @default("un")
  quantity         Decimal  @default(0) @db.Decimal(10, 3)
  minQuantity      Decimal  @default(0) @db.Decimal(10, 3) @map("min_quantity")
  maxQuantity      Decimal? @db.Decimal(10, 3) @map("max_quantity")
  unitCost         Decimal? @db.Decimal(10, 2) @map("unit_cost")
  averageCost      Decimal? @db.Decimal(10, 2) @map("average_cost")
  location         String?
  code             String?
  imageUrl         String?  @map("image_url")
  isActive         Boolean  @default(true) @map("is_active")
  // Classificação
  isConsumable     Boolean  @default(true) @map("is_consumable")
  requiresCustody  Boolean  @default(false) @map("requires_custody")
  isEpi            Boolean  @default(false) @map("is_epi")
  isUniform        Boolean  @default(false) @map("is_uniform")
  // Identificação do item (ferramentas/equipamentos)
  brand            String?
  model            String?
  serialNumber     String?  @map("serial_number")
  // Localização no depósito (endereçamento)
  locationShelf    String?  @map("location_shelf")    // ex: "A", "B", "C"
  locationSection  String?  @map("location_section")  // ex: "1", "2", "3"
  locationDetail   String?  @map("location_detail")   // ex: "Caixa 4"
  locationFull     String?  @map("location_full")     // computed: "Prateleira A / Seção 2"
  // Localização atual (qual obra)
  currentProjectId String?  @map("current_project_id")
  currentLocation  String?  @map("current_location")
  // Especificações técnicas (ferramentas/equipamentos)
  toolType         String?  @map("tool_type")         // MANUAL | ELECTRIC | PNEUMATIC | HYDRAULIC | MEASURING
  voltage          String?  @map("voltage")            // 127V | 220V | BIVOLT
  power            String?  @map("power")              // ex: "1500W", "2CV"
  // Dados de compra e garantia
  purchaseDate     DateTime? @map("purchase_date")
  warrantyMonthsTool Int?   @map("warranty_months_tool")  // meses de garantia (para ferramentas)
  warrantyExpiry   DateTime? @map("warranty_expiry")
  isUnderWarranty  Boolean  @default(false) @map("is_under_warranty")
  // Assistência técnica autorizada
  authorizedName   String?  @map("authorized_name")
  authorizedPhone  String?  @map("authorized_phone")
  authorizedAddress String? @map("authorized_address")
  authorizedCity   String?  @map("authorized_city")
  // Manutenção preventiva
  lastMaintenance  DateTime? @map("last_maintenance")
  nextMaintenance  DateTime? @map("next_maintenance")
  // Status operacional (ferramentas/equipamentos)
  toolStatus       String?   @default("AVAILABLE") @map("tool_status")
  // AVAILABLE | IN_USE | MAINTENANCE | DAMAGED | LOST
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  currentProject   Project?          @relation("StockCurrentProject", fields: [currentProjectId], references: [id])
  movements        StockMovement[]
  custodies        ToolCustody[]
  epiDeliveries    StockEpiDelivery[]
  purchaseMapItems PurchaseMapItem[]
  supplierLots     SupplierLot[]
  maintenanceRecords ToolMaintenanceRecord[]
  stockBalances    StockBalance[]
  transferItems    StockTransferItem[]
  waybillItems     WaybillItem[]
  deleteRequests   ToolDeleteRequest[]
  diaryEquipments  DiaryEquipment[]

  @@map("stock_items")
}

model StockMovement {
  id              String            @id @default(cuid())
  companyId       String            @map("company_id")
  stockItemId     String            @map("stock_item_id")
  projectId       String?           @map("project_id")
  employeeId      String?           @map("employee_id")
  responsibleId   String?           @map("responsible_id")
  basketId        String?           @map("basket_id")    // vínculo com romaneio
  type            StockMovementType
  quantity        Decimal           @db.Decimal(10, 3)
  unitCost        Decimal?          @db.Decimal(10, 2) @map("unit_cost")
  averageCostAfter Decimal?         @db.Decimal(10, 2) @map("average_cost_after")
  totalCost       Decimal?          @db.Decimal(10, 2) @map("total_cost")
  docNumber       String?           @map("doc_number")   // número do documento (OS-2026-0001)
  signatureUrl    String?           @map("signature_url")
  reason          String?
  notes           String?
  // Multi-local
  locationId      String?           @map("location_id")
  transferId      String?           @map("transfer_id")
  supplierName    String?           @map("supplier_name")
  brand           String?
  lot             String?
  createdAt       DateTime          @default(now()) @map("created_at")

  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stockItem   StockItem      @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  project     Project?       @relation(fields: [projectId], references: [id])
  employee    Employee?      @relation("StockMovementEmployee", fields: [employeeId], references: [id])
  responsible User?          @relation("StockMovementResponsible", fields: [responsibleId], references: [id])
  basket      StockBasket?   @relation(fields: [basketId], references: [id])
  location    StockLocation? @relation(fields: [locationId], references: [id])
  transfer    StockTransfer? @relation(fields: [transferId], references: [id])
  costEntries ProjectCostEntry[]

  @@map("stock_movements")
}

// ─────────────────────────────────────────
// DEPÓSITO — Lotes de Fornecedor
// ─────────────────────────────────────────

/// Rastreia lotes de compra por fornecedor (NF, validade, custo)
model SupplierLot {
  id            String    @id @default(cuid())
  companyId     String    @map("company_id")
  stockItemId   String    @map("stock_item_id")
  supplierId    String?   @map("supplier_id")
  supplierName  String?   @map("supplier_name")    // nome livre quando sem FK
  lotNumber     String?   @map("lot_number")       // número do lote
  invoiceNumber String?   @map("invoice_number")   // número da NF
  purchaseDate  DateTime? @map("purchase_date")
  quantity      Decimal   @db.Decimal(10, 3)
  unitCost      Decimal?  @db.Decimal(10, 2) @map("unit_cost")
  expiryDate    DateTime? @map("expiry_date")      // para materiais com validade
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stockItem StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  supplier  Supplier? @relation(fields: [supplierId], references: [id])

  @@map("supplier_lots")
}

// ─────────────────────────────────────────
// DEPÓSITO — Romaneio / Cesta de Saída
// ─────────────────────────────────────────

/// Romaneio de saída (cesta de itens) com assinatura digital do responsável e do recebedor
model StockBasket {
  id          String    @id @default(cuid())
  companyId   String    @map("company_id")
  docNumber   String    @map("doc_number")   // OS-2026-0001 (sequencial por empresa/ano)
  type        String    @default("OUT")       // OUT | EPI | RETURN
  status      String    @default("DRAFT")     // DRAFT | SIGNED | CANCELLED
  projectId   String?   @map("project_id")
  employeeId  String?   @map("employee_id")   // colaborador que recebe
  destinatary String?                          // Nome livre (se não for colaborador cadastrado)
  notes       String?
  /// Snapshot JSON dos itens no momento da emissão
  items       Json      @default("[]")

  // Assinaturas digitais
  senderSignatureUrl   String?   @map("sender_signature_url")
  receiverSignatureUrl String?   @map("receiver_signature_url")
  signedAt             DateTime? @map("signed_at")

  // Logística de transporte
  driverName        String?   @map("driver_name")       // motorista
  driverDocument    String?   @map("driver_document")   // CPF do motorista
  driverPhone       String?   @map("driver_phone")
  vehiclePlate      String?   @map("vehicle_plate")     // placa do veículo
  vehicleModel      String?   @map("vehicle_model")
  carrierName       String?   @map("carrier_name")      // transportadora
  carrierDocument   String?   @map("carrier_document")  // CNPJ transportadora
  carrierPhone      String?   @map("carrier_phone")
  trackingCode      String?   @map("tracking_code")
  deliveryType      String?   @map("delivery_type")     // PICKUP|DELIVERY|TRANSFER|RETURN
  estimatedArrival  DateTime? @map("estimated_arrival")
  confirmedArrival  DateTime? @map("confirmed_arrival")

  responsibleId String? @map("responsible_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project     Project?  @relation(fields: [projectId], references: [id])
  employee    Employee? @relation("BasketEmployee", fields: [employeeId], references: [id])
  responsible User?     @relation("BasketResponsible", fields: [responsibleId], references: [id])
  movements   StockMovement[]

  @@unique([companyId, docNumber])
  @@index([companyId, status])
  @@map("stock_baskets")
}

// ─────────────────────────────────────────
// EPI — Equipamentos de Proteção Individual
// ─────────────────────────────────────────

model EpiDelivery {
  id            String   @id @default(cuid())
  employeeId    String   @map("employee_id")
  responsibleId String   @map("responsible_id")
  epiName       String   @map("epi_name")
  epiCode       String?  @map("epi_code")
  quantity      Int      @default(1)
  deliveredAt   DateTime @default(now()) @map("delivered_at")
  returnedAt    DateTime? @map("returned_at")
  condition     String?
  notes         String?
  signatureUrl  String?  @map("signature_url")
  createdAt     DateTime @default(now()) @map("created_at")

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  responsible User     @relation("EpiResponsible", fields: [responsibleId], references: [id])

  @@map("epi_deliveries")
}

// ─────────────────────────────────────────
// DEPÓSITO — Custódia de Ferramentas
// ─────────────────────────────────────────

model ToolCustody {
  id              String    @id @default(cuid())
  companyId       String    @map("company_id")
  stockItemId     String    @map("stock_item_id")
  employeeId      String    @map("employee_id")
  projectId       String?   @map("project_id")
  responsibleId   String?   @map("responsible_id")
  quantity        Decimal   @default(1) @db.Decimal(10, 3)
  checkedOutAt    DateTime  @default(now()) @map("checked_out_at")
  dueDate         DateTime? @map("due_date")
  returnedAt      DateTime? @map("returned_at")
  condition           String?
  conditionOnReturn   String?   @map("condition_on_return")
  notes               String?
  // Foto e assinatura na saída
  photoUrl            String?   @map("photo_url")
  // Devolução enriquecida
  photoOnReturnUrl    String?   @map("photo_on_return_url")
  returnSignatureUrl  String?   @map("return_signature_url")
  returnedBy          String?   @map("returned_by")
  returnNotes         String?   @map("return_notes")
  createdAt           DateTime  @default(now()) @map("created_at")

  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  employee    Employee  @relation(fields: [employeeId], references: [id])
  project     Project?  @relation(fields: [projectId], references: [id])
  responsible User?     @relation("ToolCustodyResponsible", fields: [responsibleId], references: [id])

  @@map("tool_custodies")
}

// ─────────────────────────────────────────
// DEPÓSITO — Entrega de EPI/Uniforme via Estoque
// ─────────────────────────────────────────

model StockEpiDelivery {
  id              String    @id @default(cuid())
  companyId       String    @map("company_id")
  stockItemId     String    @map("stock_item_id")
  employeeId      String    @map("employee_id")
  projectId       String?   @map("project_id")
  responsibleId   String?   @map("responsible_id")
  quantity        Decimal   @default(1) @db.Decimal(10, 3)
  deliveredAt     DateTime  @default(now()) @map("delivered_at")
  returnedAt      DateTime? @map("returned_at")
  condition       String?
  notes           String?
  signatureUrl    String?   @map("signature_url")
  caNumber        String?   @map("ca_number")   // CA do equipamento EPI
  // Selfie e localização (multi-local)
  selfieUrl       String?   @map("selfie_url")
  selfieDate      DateTime? @map("selfie_date")
  locationId      String?   @map("location_id")
  size            String?                        // tamanho (P/M/G/GG)
  expiresAt       DateTime? @map("expires_at")  // validade do EPI entregue
  createdAt       DateTime  @default(now()) @map("created_at")

  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stockItem   StockItem      @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  employee    Employee       @relation(fields: [employeeId], references: [id])
  project     Project?       @relation(fields: [projectId], references: [id])
  responsible User?          @relation("StockEpiResponsible", fields: [responsibleId], references: [id])
  location    StockLocation? @relation(fields: [locationId], references: [id])

  @@map("stock_epi_deliveries")
}

// ─────────────────────────────────────────
// DEPÓSITO — Multi-local (Almoxarifados)
// ─────────────────────────────────────────

/// Local de estoque: Depósito Central ou Almoxarifado de Obra
model StockLocation {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  name        String
  type        String   // CENTRAL | WAREHOUSE
  projectId   String?  @map("project_id")
  address     String?
  description String?
  managerId   String   @map("manager_id")   // userId do responsável
  managerName String   @map("manager_name") // nome para exibição rápida
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company       Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project       Project?   @relation(fields: [projectId], references: [id])
  manager       User       @relation("LocationManager", fields: [managerId], references: [id])
  stockBalances StockBalance[]
  movements     StockMovement[]
  transfersFrom StockTransfer[] @relation("TransferFrom")
  transfersTo   StockTransfer[] @relation("TransferTo")
  permissions   StockLocationPermission[]
  epiDeliveries StockEpiDelivery[]
  waybills      Waybill[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([companyId, projectId])
  @@map("stock_locations")
}

/// Saldo de cada item em cada local de estoque
model StockBalance {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  itemId      String   @map("item_id")
  locationId  String   @map("location_id")
  quantity    Decimal  @default(0) @db.Decimal(10, 3)
  reservedQty Decimal  @default(0) @db.Decimal(10, 3) @map("reserved_qty")
  averageCost Decimal  @default(0) @db.Decimal(10, 2) @map("average_cost")
  totalValue  Decimal  @default(0) @db.Decimal(15, 2) @map("total_value")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company  Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  item     StockItem     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  location StockLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([itemId, locationId])
  @@index([companyId, locationId])
  @@index([companyId, itemId])
  @@map("stock_balances")
}

/// Transferência de estoque entre locais (com fluxo de aceite)
model StockTransfer {
  id               String    @id @default(cuid())
  companyId        String    @map("company_id")
  docNumber        String    @map("doc_number")   // TRF-YYYY-NNNN
  fromLocationId   String    @map("from_location_id")
  toLocationId     String    @map("to_location_id")
  status           String    @default("PENDING")
  // PENDING | ACCEPTED | PARTIAL | REJECTED | CANCELLED
  requestedBy      String    @map("requested_by")
  requestedAt      DateTime  @default(now()) @map("requested_at")
  respondedBy      String?   @map("responded_by")
  respondedAt      DateTime? @map("responded_at")
  rejectionReason  String?   @map("rejection_reason")
  notes            String?
  senderSignature  String?   @map("sender_signature")
  receiverSignature String?  @map("receiver_signature")
  signedAt         DateTime? @map("signed_at")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fromLocation StockLocation @relation("TransferFrom", fields: [fromLocationId], references: [id])
  toLocation   StockLocation @relation("TransferTo", fields: [toLocationId], references: [id])
  requester    User          @relation("TransferRequester", fields: [requestedBy], references: [id])
  responder    User?         @relation("TransferResponder", fields: [respondedBy], references: [id])
  items        StockTransferItem[]
  movements    StockMovement[]

  @@index([companyId, status])
  @@index([companyId, fromLocationId])
  @@index([companyId, toLocationId])
  @@map("stock_transfers")
}

/// Item de uma transferência entre locais
model StockTransferItem {
  id           String   @id @default(cuid())
  transferId   String   @map("transfer_id")
  itemId       String   @map("item_id")
  requestedQty Decimal  @db.Decimal(10, 3) @map("requested_qty")
  acceptedQty  Decimal? @db.Decimal(10, 3) @map("accepted_qty")
  unitCost     Decimal  @default(0) @db.Decimal(10, 2) @map("unit_cost")
  notes        String?

  transfer StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  item     StockItem     @relation(fields: [itemId], references: [id])

  @@map("stock_transfer_items")
}

/// Permissão de usuário em um local de estoque
model StockLocationPermission {
  id         String   @id @default(cuid())
  companyId  String   @map("company_id")
  userId     String   @map("user_id")
  locationId String   @map("location_id")
  role       String   // MANAGER | OPERATOR
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  location StockLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([userId, locationId])
  @@map("stock_location_permissions")
}

// ─────────────────────────────────────────
// DEPÓSITO — Reclassificação de Custo por Obra
// ─────────────────────────────────────────

model ProjectCostEntry {
  id              String    @id @default(cuid())
  companyId       String    @map("company_id")
  projectId       String    @map("project_id")
  stockMovementId String?   @map("stock_movement_id")
  stageId         String?   @map("stage_id")
  description     String
  category        String?
  quantity        Decimal   @db.Decimal(10, 3)
  unitCost        Decimal   @db.Decimal(10, 2) @map("unit_cost")
  totalCost       Decimal   @db.Decimal(10, 2) @map("total_cost")
  date            DateTime  @default(now())
  notes           String?
  needsAppropriation Boolean  @default(false) @map("needs_appropriation")
  appropriatedBy  String?   @map("appropriated_by")
  appropriatedAt  DateTime? @map("appropriated_at")
  origin          String?   @default("MANUAL")
  isCancelled     Boolean   @default(false) @map("is_cancelled")
  cancelledAt     DateTime? @map("cancelled_at")
  cancelledBy     String?   @map("cancelled_by")
  waybillId       String?   @map("waybill_id")
  createdAt       DateTime  @default(now()) @map("created_at")

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project       Project        @relation(fields: [projectId], references: [id])
  stage         ProjectStage?  @relation(fields: [stageId], references: [id])
  stockMovement StockMovement? @relation(fields: [stockMovementId], references: [id])

  @@map("project_cost_entries")
}

// ─────────────────────────────────────────
// FERRAMENTAS & EQUIPAMENTOS
// ─────────────────────────────────────────

model ToolMovement {
  id            String           @id @default(cuid())
  companyId     String           @map("company_id")
  employeeId    String?          @map("employee_id")
  responsibleId String           @map("responsible_id")
  toolName      String           @map("tool_name")
  toolCode      String?          @map("tool_code")
  type          ToolMovementType
  projectId     String?          @map("project_id")
  checkedOutAt  DateTime?        @map("checked_out_at")
  returnedAt    DateTime?        @map("returned_at")
  condition     String?
  notes         String?
  createdAt     DateTime         @default(now()) @map("created_at")

  employee    Employee? @relation("ToolEmployee", fields: [employeeId], references: [id])
  responsible User      @relation("ToolResponsible", fields: [responsibleId], references: [id])
  project     Project?  @relation(fields: [projectId], references: [id])

  @@map("tool_movements")
}

// ─────────────────────────────────────────
// MAPA DE COMPRAS / COTAÇÕES / PEDIDOS
// ─────────────────────────────────────────

model PurchaseMap {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  projectId   String?  @map("project_id")
  name        String
  description String?
  status      String   @default("draft")
  dueDate     DateTime? @map("due_date")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company    Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project    Project?            @relation(fields: [projectId], references: [id])
  items      PurchaseMapItem[]
  quotations PurchaseQuotation[]
  orders     PurchaseOrder[]

  @@map("purchase_maps")
}

model PurchaseMapItem {
  id            String  @id @default(cuid())
  purchaseMapId String  @map("purchase_map_id")
  stockItemId   String? @map("stock_item_id")
  name          String
  unit          String  @default("un")
  quantity      Decimal @db.Decimal(10, 3)
  notes         String?

  purchaseMap PurchaseMap @relation(fields: [purchaseMapId], references: [id], onDelete: Cascade)
  stockItem   StockItem?  @relation(fields: [stockItemId], references: [id])

  @@map("purchase_map_items")
}

model PurchaseQuotation {
  id            String   @id @default(cuid())
  purchaseMapId String   @map("purchase_map_id")
  supplierId    String   @map("supplier_id")
  totalAmount   Decimal? @db.Decimal(15, 2) @map("total_amount")
  validUntil    DateTime? @map("valid_until")
  notes         String?
  attachmentUrl String?  @map("attachment_url")
  isSelected    Boolean  @default(false) @map("is_selected")
  createdAt     DateTime @default(now()) @map("created_at")

  purchaseMap PurchaseMap @relation(fields: [purchaseMapId], references: [id], onDelete: Cascade)
  supplier    Supplier    @relation(fields: [supplierId], references: [id])

  @@map("purchase_quotations")
}

model PurchaseOrder {
  id            String              @id @default(cuid())
  purchaseMapId String              @map("purchase_map_id")
  supplierId    String              @map("supplier_id")
  status        PurchaseOrderStatus @default(DRAFT)
  totalAmount   Decimal             @db.Decimal(15, 2) @map("total_amount")
  expectedAt    DateTime?           @map("expected_at")
  receivedAt    DateTime?           @map("received_at")
  notes         String?
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  purchaseMap PurchaseMap @relation(fields: [purchaseMapId], references: [id], onDelete: Cascade)
  supplier    Supplier    @relation(fields: [supplierId], references: [id])

  @@map("purchase_orders")
}

// ─────────────────────────────────────────
// VEÍCULOS
// ─────────────────────────────────────────

model Vehicle {
  id           String        @id @default(cuid())
  companyId    String        @map("company_id")
  name         String
  plate        String?       @unique
  brand        String?
  model        String?
  year         Int?
  color        String?
  chassi       String?
  renavam      String?
  status       VehicleStatus @default(ACTIVE)
  currentKm    Int           @default(0) @map("current_km")
  imageUrl     String?       @map("image_url")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  company       Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  maintenances  VehicleMaintenance[]
  refuels       VehicleRefuel[]

  @@map("vehicles")
}

model VehicleMaintenance {
  id          String   @id @default(cuid())
  vehicleId   String   @map("vehicle_id")
  description String
  cost        Decimal? @db.Decimal(10, 2)
  km          Int?
  provider    String?
  date        DateTime @default(now())
  nextDate    DateTime? @map("next_date")
  nextKm      Int?     @map("next_km")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("vehicle_maintenances")
}

model VehicleRefuel {
  id            String   @id @default(cuid())
  vehicleId     String   @map("vehicle_id")
  fuelType      String   @map("fuel_type")
  liters        Decimal  @db.Decimal(8, 3)
  pricePerLiter Decimal  @db.Decimal(8, 3) @map("price_per_liter")
  totalCost     Decimal  @db.Decimal(10, 2) @map("total_cost")
  km            Int?
  station       String?
  date          DateTime @default(now())
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("vehicle_refuels")
}

// ─────────────────────────────────────────
// PROBLEMAS / OCORRÊNCIAS
// ─────────────────────────────────────────

model Problem {
  id           String          @id @default(cuid())
  companyId    String          @map("company_id")
  projectId    String?         @map("project_id")
  reportedById String          @map("reported_by_id")
  title        String
  description  String
  status       ProblemStatus   @default(OPEN)
  priority     ProblemPriority @default(MEDIUM)
  category     String?
  imageUrls    String[]        @map("image_urls")
  resolvedAt   DateTime?       @map("resolved_at")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  company  Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project  Project?         @relation(fields: [projectId], references: [id])
  comments ProblemComment[]

  @@map("problems")
}

model ProblemComment {
  id        String   @id @default(cuid())
  problemId String   @map("problem_id")
  userId    String   @map("user_id")
  content   String
  imageUrls String[] @map("image_urls")
  createdAt DateTime @default(now()) @map("created_at")

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@map("problem_comments")
}

// ─────────────────────────────────────────
// DIÁRIO DE OBRA
// ─────────────────────────────────────────

model DiaryEntry {
  id           String      @id @default(cuid())
  projectId    String      @map("project_id")
  authorId     String      @map("author_id")
  date         DateTime    @default(now())

  // ── Número sequencial por obra ──────────────────────────────────
  reportNumber     String?  @map("report_number")       // RDO-001, RDO-002…
  isComplement     Boolean  @default(false) @map("is_complement")
  parentReportId   String?  @map("parent_report_id")    // ID do RDO principal do mesmo dia
  complementLetter String?  @map("complement_letter")   // A, B, C…

  // ── Condições climáticas por período ────────────────────────────
  weatherMorning   WeatherCondition? @map("weather_morning")
  weatherAfternoon WeatherCondition? @map("weather_afternoon")
  weatherNight     WeatherCondition? @map("weather_night")

  // ── Medição pluviométrica (mm) por período ───────────────────────
  rainMorningMm   Float @default(0) @map("rain_morning_mm")
  rainAfternoonMm Float @default(0) @map("rain_afternoon_mm")
  rainNightMm     Float @default(0) @map("rain_night_mm")
  totalRainMm     Float @default(0) @map("total_rain_mm")   // calculado: soma dos 3

  // ── Praticabilidade por período ──────────────────────────────────
  workableMorning       Boolean @default(true) @map("workable_morning")
  workableAfternoon     Boolean @default(true) @map("workable_afternoon")
  workableNight         Boolean @default(true) @map("workable_night")
  suggestedUnworkable   Boolean @default(false) @map("suggested_unworkable")
  unworkableConfirmedBy String? @map("unworkable_confirmed_by")

  // ── Campos legados (mantidos para backward compat) ───────────────
  weather      String?
  temperature  Decimal?    @db.Decimal(4, 1)
  workers      Int?

  // ── Conteúdo do relatório ────────────────────────────────────────
  generalActivities String? @db.Text @map("general_activities") // resumo geral
  generalNotes      String? @db.Text @map("general_notes")
  notesPublic       Boolean @default(false) @map("notes_public")
  activities   String? @db.Text
  observations String? @db.Text

  // ── DDS ─────────────────────────────────────────────────────────
  ddsTheme String?   @map("dds_theme")
  ddsDone  Boolean   @default(false) @map("dds_done")
  ddsTime  DateTime? @map("dds_time")

  // ── Mídias ──────────────────────────────────────────────────────
  imageUrls String[] @map("image_urls")

  // ── Aprovação / Rejeição ─────────────────────────────────────────
  status        DiaryStatus @default(DRAFT)
  approvedById  String?     @map("approved_by_id")
  approvedAt    DateTime?   @map("approved_at")
  rejectedById  String?     @map("rejected_by_id")
  rejectedAt    DateTime?   @map("rejected_at")
  rejectionNote String?     @map("rejection_note")

  // ── Auditoria ───────────────────────────────────────────────────
  updatedBy String? @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // ── Assinaturas ─────────────────────────────────────────────────────────
  authorSignatureUrl   String?   @map("author_signature_url")
  approverSignatureUrl String?   @map("approver_signature_url")
  fiscalSignatureUrl   String?   @map("fiscal_signature_url")
  authorSigned         Boolean   @default(false) @map("author_signed")
  approverSigned       Boolean   @default(false) @map("approver_signed")
  fiscalSigned         Boolean   @default(false) @map("fiscal_signed")
  fiscalName           String?   @map("fiscal_name")
  fiscalEmail          String?   @map("fiscal_email")
  fiscalDocument       String?   @map("fiscal_document")   // CPF do fiscal externo
  // Token público para fiscal externo (TTL 48h):
  fiscalSignatureToken          String?   @unique @map("fiscal_signature_token")
  fiscalSignatureTokenExpiresAt DateTime? @map("fiscal_signature_token_expires_at")
  // Hash de verificação pública:
  verificationHash String? @unique @map("verification_hash")

  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author     User           @relation("DiaryAuthor",   fields: [authorId],    references: [id])
  approvedBy User?          @relation("DiaryApprover", fields: [approvedById], references: [id])
  rejectedBy User?          @relation("DiaryRejector", fields: [rejectedById], references: [id])
  parentReport      DiaryEntry?  @relation("DiaryComplements", fields: [parentReportId], references: [id])
  complementReports DiaryEntry[] @relation("DiaryComplements")
  comments      DiaryComment[]
  stageEntries  DiaryStageEntry[]
  occurrences   DiaryOccurrence[]
  rainRecord    DiaryRainRecord?
  equipments    DiaryEquipment[]

  @@index([fiscalSignatureToken])
  @@map("diary_entries")
}

/// Progresso por etapa registrado em cada relatório diário
model DiaryStageEntry {
  id               String   @id @default(cuid())
  diaryId          String   @map("diary_id")
  stageId          String   @map("stage_id")
  previousProgress Float    @default(0) @map("previous_progress")  // % anterior (puxado do ProjectStage)
  currentProgress  Float    @default(0) @map("current_progress")   // % atual informado
  progressDelta    Float    @default(0) @map("progress_delta")      // diferença calculada
  activities       String   @default("") @db.Text
  comments         String?  @db.Text
  photos           String[] @default([])
  createdAt        DateTime @default(now()) @map("created_at")

  diary DiaryEntry   @relation(fields: [diaryId], references: [id], onDelete: Cascade)
  stage ProjectStage @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@unique([diaryId, stageId])
  @@map("diary_stage_entries")
}

/// Ocorrências registradas no relatório diário
model DiaryOccurrence {
  id             String             @id @default(cuid())
  diaryId        String             @map("diary_id")
  type           OccurrenceType     @default(OTHER)
  severity       OccurrenceSeverity @default(LOW)
  description    String             @db.Text
  action         String?            @db.Text   // providência tomada
  responsible    String?
  visitorName    String?            @map("visitor_name")
  visitorCompany String?            @map("visitor_company")
  visitorPurpose String?            @map("visitor_purpose")
  photos         String[]           @default([])
  notifyManager  Boolean            @default(false) @map("notify_manager")
  createdAt      DateTime           @default(now()) @map("created_at")

  diary DiaryEntry @relation(fields: [diaryId], references: [id], onDelete: Cascade)

  @@map("diary_occurrences")
}

/// Histórico pluviométrico vinculado ao relatório diário
model DiaryRainRecord {
  id               String   @id @default(cuid())
  companyId        String   @map("company_id")
  projectId        String   @map("project_id")
  diaryId          String   @unique @map("diary_id")
  date             DateTime
  morningMm        Float    @default(0) @map("morning_mm")
  afternoonMm      Float    @default(0) @map("afternoon_mm")
  nightMm          Float    @default(0) @map("night_mm")
  totalMm          Float    @default(0) @map("total_mm")
  isUnworkable     Boolean  @default(false) @map("is_unworkable")
  unworkableReason String?  @map("unworkable_reason")
  createdAt        DateTime @default(now()) @map("created_at")

  project Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  diary   DiaryEntry @relation(fields: [diaryId], references: [id], onDelete: Cascade)

  @@index([projectId, date])
  @@map("diary_rain_records")
}

/// Confirmação de presença e registro de uso de ferramentas no RDO
model DiaryEquipment {
  id           String    @id @default(cuid())
  companyId    String    @map("company_id")
  diaryEntryId String    @map("diary_entry_id")
  itemId       String    @map("item_id")          // StockItem (ferramenta)
  // Presença (diário de obra)
  confirmed    Boolean   @default(false)
  confirmedAt  DateTime? @map("confirmed_at")
  confirmedBy  String?   @map("confirmed_by")     // userId
  // Uso no RDO
  usedInRdo    Boolean   @default(false) @map("used_in_rdo")
  usedAt       DateTime? @map("used_at")
  usedBy       String?   @map("used_by")
  usageNotes   String?   @map("usage_notes")
  // Alertas
  alertSent    Boolean   @default(false) @map("alert_sent")
  notes        String?
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")

  diaryEntry   DiaryEntry @relation(fields: [diaryEntryId], references: [id], onDelete: Cascade)
  item         StockItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([diaryEntryId])
  @@index([companyId])
  @@map("diary_equipments")
}

/// Comentários em registros do diário (internos e externos/clientes)
model DiaryComment {
  id           String     @id @default(cuid())
  diaryEntryId String     @map("diary_entry_id")
  authorId     String     @map("author_id")
  authorName   String     @map("author_name")
  authorType   MemberType @map("author_type")
  content      String
  /// true = visível só para membros internos; false = visível também para externos/clientes
  isInternal   Boolean    @default(false) @map("is_internal")
  createdAt    DateTime   @default(now()) @map("created_at")

  diaryEntry DiaryEntry @relation(fields: [diaryEntryId], references: [id], onDelete: Cascade)
  author     User       @relation(fields: [authorId], references: [id])

  @@map("diary_comments")
}

// ─────────────────────────────────────────
// DOCUMENTOS & ASSINATURAS
// ─────────────────────────────────────────

model Document {
  id          String       @id @default(cuid())
  companyId   String       @map("company_id")
  projectId   String?      @map("project_id")
  templateId  String?      @map("template_id")
  title       String
  type        DocumentType @default(OTHER)
  content     String?      @db.Text
  fileUrl     String?      @map("file_url")
  tags        String[]
  isPublished Boolean      @default(false) @map("is_published")
  expiresAt   DateTime?    @map("expires_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  company    Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project    Project?          @relation(fields: [projectId], references: [id])
  template   DocumentTemplate? @relation(fields: [templateId], references: [id])
  signatures Signature[]

  @@map("documents")
}

model DocumentTemplate {
  id          String       @id @default(cuid())
  companyId   String       @map("company_id")
  name        String
  type        DocumentType @default(OTHER)
  content     String       @db.Text
  variables   Json?
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  documents Document[]

  @@map("document_templates")
}

model Signature {
  id            String          @id @default(cuid())
  documentId    String          @map("document_id")
  userId        String          @map("user_id")
  status        SignatureStatus @default(PENDING)
  signedAt      DateTime?       @map("signed_at")
  signatureData String?         @map("signature_data") @db.Text
  ipAddress     String?         @map("ip_address")
  token         String          @unique @default(cuid())
  expiresAt     DateTime?       @map("expires_at")
  createdAt     DateTime        @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@map("signatures")
}

// ─────────────────────────────────────────
// AUDITORIA
// ─────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  userId      String?  @map("user_id")    // null = ação do sistema
  action      String   // CREATE | UPDATE | DELETE | APPROVE | REJECT | SUBMIT |
                       // COMMENT | UPLOAD | LOGIN | LOGOUT | TRANSFER | REVERSE |
                       // PAY | RECEIVE | CANCEL | INVITE | PERMISSION_CHANGE |
                       // EXPORT | PRINT | REVERSE_TRANSFER
  module      String   // FINANCIAL | PROJECT | DIARY | DEPOSIT | FLEET |
                       // PURCHASES | COLLABORATORS | TRACKER | SETTINGS | AUTH | REPORTS
  entity      String   // FinancialTransaction | Project | DiaryEntry | BankAccount | etc.
  entityId    String?  @map("entity_id")
  entityName  String?  @map("entity_name")
  description String
  before      Json?
  after       Json?
  metadata    Json?
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@index([companyId, createdAt(sort: Desc)])
  @@index([companyId, module])
  @@index([companyId, entity, entityId])
  @@index([companyId, userId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────
// CATÁLOGO GLOBAL & DDS
// ─────────────────────────────────────────

model GlobalMaterial {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String?
  unit        String   @default("un")
  ncm         String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("global_materials")
}

model DdsTheme {
  id          String      @id @default(cuid())
  companyId   String?     @map("company_id")        // null = DDS do sistema; preenchido = DDS da empresa
  title       String
  content     String      @db.Text
  category    DdsCategory @default(OTHER)
  tags        String[]    @default([])
  duration    Int         @default(15)              // duração sugerida em minutos
  order       Int         @default(0)
  imageUrl    String?     @map("image_url")
  isActive    Boolean     @default(true) @map("is_active")
  createdById String?     @map("created_by_id")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("DdsCreatedBy", fields: [createdById], references: [id])

  @@index([companyId, category])
  @@map("dds_themes")
}

// ── ROMANEIO ──────────────────────────────────────────────────────────────────

model Waybill {
  id         String @id @default(cuid())
  companyId  String @map("company_id")
  docNumber  String @map("doc_number") // ROM-2025-0001

  // Categoria — SEMPRE separado:
  category String // MATERIAL | TOOL | EPI_UNIFORM

  // Status:
  status String @default("DRAFT") @map("status")
  // DRAFT        = rascunho (pode ter vários)
  // EMITTED      = emitido, aguardando saída
  // IN_TRANSIT   = motorista a caminho (pendente assinatura recebedor)
  // COMPLETED    = concluído, tudo assinado
  // CANCELLED    = cancelado

  // Tipo de saída:
  exitType String @map("exit_type") // DRIVER_DELIVERY | DIRECT_PICKUP
  // DRIVER_DELIVERY = motorista entrega na obra (pendente assinatura)
  // DIRECT_PICKUP   = colaborador retira pessoalmente (baixa imediata)

  // Local de origem:
  locationId String @map("location_id")

  // Destino:
  destinationProjectId String? @map("destination_project_id")
  destinationName      String? @map("destination_name") // se destino externo

  // ── MOTORISTA ──
  driverType       String? @map("driver_type") // EMPLOYEE | EXTERNAL
  driverEmployeeId String? @map("driver_employee_id") // se colaborador interno
  driverName       String? @map("driver_name") // nome (interno ou avulso)
  driverDocument   String? @map("driver_document") // CPF
  driverPhone      String? @map("driver_phone")
  vehiclePlate     String? @map("vehicle_plate")
  vehicleModel     String? @map("vehicle_model")

  // ── RECEBEDOR ──
  receiverType       String? @map("receiver_type") // EMPLOYEE | EXTERNAL
  receiverEmployeeId String? @map("receiver_employee_id") // se colaborador interno
  receiverName       String? @map("receiver_name")
  receiverDocument   String? @map("receiver_document") // CPF ou outro documento
  receiverPhone      String? @map("receiver_phone")
  receiverRole       String? @map("receiver_role") // função/cargo

  // ── ASSINATURAS ──
  // Expedidor (almoxarife que emitiu):
  senderUserId       String?   @map("sender_user_id")
  senderName         String?   @map("sender_name")
  senderSignatureUrl String?   @map("sender_signature_url")
  senderSignedAt     DateTime? @map("sender_signed_at")

  // Motorista:
  driverSignatureUrl String?   @map("driver_signature_url")
  driverSignedAt     DateTime? @map("driver_signed_at")

  // Recebedor:
  receiverSignatureUrl String?   @map("receiver_signature_url")
  receiverSignedAt     DateTime? @map("receiver_signed_at")

  // Link público para assinatura remota:
  signatureToken          String?   @unique @map("signature_token")
  signatureTokenExpiresAt DateTime? @map("signature_token_expires_at")

  // Hash de verificação pública (gerado quando status → COMPLETED):
  verificationHash String? @unique @map("verification_hash")

  // Observações do recebedor ao assinar:
  receiverNotes String? @map("receiver_notes")

  // ── PENDÊNCIA ──
  hasPendency          Boolean   @default(false) @map("has_pendency")
  pendencyNotes        String?   @map("pendency_notes")
  pendencyResolvedAt   DateTime? @map("pendency_resolved_at")
  pendencyResolvedBy   String?   @map("pendency_resolved_by")

  // ── DATAS ──
  emittedAt    DateTime? @map("emitted_at")
  dispatchedAt DateTime? @map("dispatched_at") // quando saiu com o motorista
  receivedAt   DateTime? @map("received_at")   // quando foi recebido

  notes     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company            Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  location           StockLocation @relation(fields: [locationId], references: [id])
  destinationProject Project?      @relation(fields: [destinationProjectId], references: [id])
  driverEmployee     Employee?     @relation("WaybillDriver", fields: [driverEmployeeId], references: [id])
  receiverEmployee   Employee?     @relation("WaybillReceiver", fields: [receiverEmployeeId], references: [id])
  senderUser         User?         @relation(fields: [senderUserId], references: [id])
  items              WaybillItem[]
  pendencies         WaybillPendency[]

  @@index([companyId, status])
  @@index([companyId, category])
  @@index([companyId, locationId])
  @@index([signatureToken])
  @@index([verificationHash])
  @@map("waybills")
}

model WaybillItem {
  id        String @id @default(cuid())
  waybillId String @map("waybill_id")
  itemId    String @map("item_id")

  // Quantidades:
  requestedQty Decimal  @map("requested_qty") @db.Decimal(10, 3)
  receivedQty  Decimal? @map("received_qty")  @db.Decimal(10, 3)
  pendingQty   Decimal? @map("pending_qty")   @db.Decimal(10, 3)

  unitCost  Decimal @default(0) @map("unit_cost")  @db.Decimal(10, 2)
  totalCost Decimal @default(0) @map("total_cost") @db.Decimal(15, 2)

  // Para ferramentas — detalhes individuais:
  serialNumber   String? @map("serial_number")
  toolBrand      String? @map("tool_brand")
  toolModel      String? @map("tool_model")
  toolCondition  String? @map("tool_condition") // BOM | REGULAR | DANIFICADO

  // Observação do recebedor neste item:
  receiverNotes String? @map("receiver_notes")

  // Se item foi rejeitado/faltando:
  status String @default("OK") // OK | MISSING | DAMAGED | REJECTED

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  waybill    Waybill          @relation(fields: [waybillId], references: [id], onDelete: Cascade)
  item       StockItem        @relation(fields: [itemId], references: [id])
  pendencies WaybillPendency[]

  @@index([waybillId])
  @@index([itemId])
  @@map("waybill_items")
}

model WaybillPendency {
  id        String @id @default(cuid())
  companyId String @map("company_id")
  waybillId String @map("waybill_id")

  type        String // MISSING_ITEM | DAMAGED | QUANTITY_DIVERGENCE | OTHER
  description String

  // Item relacionado (se for item específico):
  waybillItemId    String?  @map("waybill_item_id")
  itemName         String?  @map("item_name")
  quantityExpected Decimal? @map("quantity_expected") @db.Decimal(10, 3)
  quantityReceived Decimal? @map("quantity_received") @db.Decimal(10, 3)

  // Responsável por resolver:
  assignedTo String? @map("assigned_to") // userId

  status String @default("OPEN")
  // OPEN | IN_ANALYSIS | RESOLVED | IGNORED

  resolvedAt      DateTime? @map("resolved_at")
  resolvedBy      String?   @map("resolved_by")
  resolutionNotes String?   @map("resolution_notes")

  // Alerta enviado para o gestor:
  alertSentAt DateTime? @map("alert_sent_at")
  alertSentTo String?   @map("alert_sent_to")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  waybill     Waybill      @relation(fields: [waybillId], references: [id], onDelete: Cascade)
  waybillItem WaybillItem? @relation(fields: [waybillItemId], references: [id])

  @@index([companyId, status])
  @@index([waybillId])
  @@map("waybill_pendencies")
}

// ─────────────────────────────────────────
// NOTIFICAÇÕES
// ─────────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  companyId String    @map("company_id")
  userId    String    @map("user_id")
  title     String
  message   String
  type      String    @default("INFO")   // INFO | WARNING | ACTION_REQUIRED
  link      String?
  isRead    Boolean   @default(false) @map("is_read")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId, userId, isRead])
  @@map("notifications")
}

// ─────────────────────────────────────────
// SOLICITAÇÃO DE EXCLUSÃO DE FERRAMENTA
// ─────────────────────────────────────────

model ToolDeleteRequest {
  id          String    @id @default(cuid())
  companyId   String    @map("company_id")
  itemId      String    @map("item_id")
  requestedBy String    @map("requested_by")
  reason      String
  status      String    @default("PENDING")  // PENDING | APPROVED | REJECTED
  reviewedBy  String?   @map("reviewed_by")
  reviewNotes String?   @map("review_notes")
  reviewedAt  DateTime? @map("reviewed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  item      StockItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  requestor User      @relation("DeleteRequestor", fields: [requestedBy], references: [id])

  @@index([companyId, status])
  @@index([itemId])
  @@map("tool_delete_requests")
}
